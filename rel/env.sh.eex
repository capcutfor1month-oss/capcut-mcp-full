#!/bin/sh
# An MCP stdio server talks only over stdin/stdout — it never needs Erlang
# distribution. Leaving distribution on (the mix-release default of "name")
# registers a node name, so a second instance launched while the first is
# alive dies with "the name ... seems to be in use by another Erlang node".
# MCP clients routinely spawn a probe instance alongside the real connection,
# so that clash presents as a server that connects but then times out on the
# first tool call. "none" lets any number of instances coexist.
export RELEASE_DISTRIBUTION=none
